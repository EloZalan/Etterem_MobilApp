<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="WaiterApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:WaiterApp.Views"
    Shell.FlyoutBehavior="Disabled">
    <!--Shell.BackgroundColor="{x:StaticResource BackGroundGraylight}">-->
    
    <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" />
    <ShellContent Route="tables" ContentTemplate="{DataTemplate views:TablesPage}" />
    <ShellContent Route="tableDetails" ContentTemplate="{DataTemplate views:TableDetailsPage}" />
    <ShellContent Route="pay" ContentTemplate="{DataTemplate views:PayPage}"/>
</Shell>
