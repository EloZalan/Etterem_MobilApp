<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WaiterApp.Views.TableDetailsPage"
             x:Name="Page"
             BackgroundColor="{x:StaticResource BackGroundGray}"
             Shell.BackgroundColor="{x:StaticResource BackGroundGraylight}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Frame BackgroundColor="{x:StaticResource BackGroundGraylight}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Rendelés" FontAttributes="Bold" FontSize="22" HorizontalOptions="Center" TextColor="White"/>
                    <Label Text="{Binding CurrentOrderLabel}" HorizontalOptions="Center" Padding="0,0,0,10"/>
                    <Button Text="Asztal megnyitása" Command="{Binding OpenOrderCommand}" WidthRequest="300" IsVisible="{Binding ShowOpenOrderButton}"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{x:StaticResource BackGroundGraylight}" IsVisible="{Binding HasOrder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Tételek" FontAttributes="Bold" FontSize="22" HorizontalOptions="Center" TextColor="White"/>

                    <CollectionView ItemsSource="{Binding OrderItems}" SelectionMode="None" HeightRequest="220" EmptyView="Még nem rendeltek." HorizontalOptions="Center">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,4" Padding="12,10" CornerRadius="12" BackgroundColor="#3A3A3A" BorderColor="#555555">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                        <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontAttributes="Bold" TextColor="White"/>
                                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding LineTotalLabel}" TextColor="White" HorizontalTextAlignment="End"/>
                                        <Label Grid.Row="1" Grid.Column="0" Text="{Binding Quantity, StringFormat='mennyiség: {0}'}" TextColor="#D0D0D0"/>
                                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding PriceLabel}" TextColor="#D0D0D0" HorizontalTextAlignment="End"/>
                                        <Button Grid.Row="2" Grid.ColumnSpan="2"
                                                Text="Törlés"
                                                Margin="0,10,0,0"
                                                BackgroundColor="#B22222"
                                                TextColor="White"
                                                Command="{Binding Source={x:Reference Page}, Path=BindingContext.DeleteOrderItemCommand}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{x:StaticResource BackGroundGraylight}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Rendelhető tételek" FontAttributes="Bold" FontSize="22" HorizontalOptions="Center" Padding="0,0,0,10" TextColor="White"/>

                    <Picker Title="Category"
                            ItemsSource="{Binding Categories}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedCategory}" 
                            HorizontalTextAlignment="Center"
                            WidthRequest="250"/>

                    <Picker Title="Menu Item"
                            ItemsSource="{Binding MenuItems}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedMenuItem}" 
                            HorizontalTextAlignment="Center"
                            WidthRequest="250"/>

                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center" Padding="0,0,0,10">
                        <Button Text="-" WidthRequest="40" Command="{Binding DecreaseQuantityCommand}" />
                        <Label Text="{Binding Quantity}" VerticalTextAlignment="Center" FontSize="18" />
                        <Button Text="+" WidthRequest="40" Command="{Binding IncreaseQuantityCommand}" />
                    </HorizontalStackLayout>

                    <Button Text="Megrendelés" Command="{Binding AddItemCommand}" WidthRequest="300"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{x:StaticResource BackGroundGraylight}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Fizetés" FontAttributes="Bold" FontSize="22" HorizontalOptions="Center" Padding="0,0,0,10" TextColor="White"/>
                    <Button Text="Késznek jelentés" Command="{Binding MarkReadyCommand}" WidthRequest="300" BackgroundColor="#FFBF00" TextColor="Black"/>
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Button Text="Készpénz" Command="{Binding GoToPayCommand}" CommandParameter="cash" HorizontalOptions="Fill" WidthRequest="145" BackgroundColor="#009E60"/>
                        <Button Text="Kártya" Command="{Binding GoToPayCommand}" CommandParameter="card" HorizontalOptions="Fill" WidthRequest="145" BackgroundColor="#1F51FF"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Label Text="{Binding StatusMessage}" TextColor="Gray" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
