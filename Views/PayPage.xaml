<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.PayPage"
             BackgroundColor="{x:StaticResource BackGroundGray}">
    <VerticalStackLayout>
        <VerticalStackLayout Spacing="12" Padding="20">
            <Label 
                Text="Pay By Cash"
                Margin="0,30,0,0"
                HorizontalOptions="Center" />

            <Button 
                Text="Confirm Cash Payment"
                HorizontalOptions="Center" 
                BackgroundColor="#009E60"
                TextColor="White"
                WidthRequest="300"
                HeightRequest="80"
                Command="{Binding PayCashCommand}" />


        </VerticalStackLayout>
        <VerticalStackLayout Spacing="12" Padding="20">
            <Label
                Text="Pay By Card"
                VerticalOptions="Center" 
                HorizontalOptions="Center" />
            
            <Button 
                Text="Confirm Card Payment"
                HorizontalOptions="Center" 
                BackgroundColor="#1F51FF"
                TextColor="White"
                WidthRequest="300"
                HeightRequest="80"
                Command="{Binding PayCardCommand}" />




        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentView>
