<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WaiterApp.Views.PayPage"
             BackgroundColor="{StaticResource BackGroundGray}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Frame BackgroundColor="{StaticResource BackGroundGraylight}" >
                <VerticalStackLayout Spacing="8">
                    <Label Text="Fizetés" FontAttributes="Bold" FontSize="24" HorizontalOptions="Center" TextColor="White" />
                    <Label Text="{Binding CurrentOrderLabel}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{StaticResource BackGroundGraylight}" IsVisible="{Binding IsCashPaymentVisible}">
                <VerticalStackLayout Spacing="12" Padding="8">
                    <Label Text="Fizetés készpénzzel"
                           Margin="0,10,0,0"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <Button Text="Fizetés elfogadása"
                            HorizontalOptions="Center"
                            BackgroundColor="#009E60"
                            TextColor="White"
                            WidthRequest="300"
                            HeightRequest="80"
                            Command="{Binding PayCashCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{StaticResource BackGroundGraylight}" IsVisible="{Binding IsCardPaymentVisible}">
                <VerticalStackLayout Spacing="12" Padding="8">
                    <Label Text="Fizetés Kártyával"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <Label Text="Használd a telefon NFC szenzorát. Érzékelés után megtörténik a fizetés."
                           HorizontalTextAlignment="Center"
                           TextColor="LightGray" />

                    <Button Text="Fizetés indítása"
                            HorizontalOptions="Center"
                            BackgroundColor="#1F51FF"
                            TextColor="White"
                            WidthRequest="300"
                            HeightRequest="80"
                            Command="{Binding PayCardCommand}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
