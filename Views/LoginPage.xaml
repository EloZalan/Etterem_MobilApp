<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:tool="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="WaiterApp.Views.LoginPage"
             BackgroundColor="{x:StaticResource BackGroundGray}">
    <ContentPage.Behaviors>
        <tool:StatusBarBehavior StatusBarColor="{x:StaticResource Black}"/>
    </ContentPage.Behaviors>
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="BackgroundStyle" TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource BackGroundGray}" />
            </Style>
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="TextColor" Value="{StaticResource White}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="14,10" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Center">
            <Label Text="Waiter Login"
                   FontSize="30"
                   FontAttributes="Bold" 
                   TextColor="{x:StaticResource Primary}"/>

            <Label Text="Sign in to manage your tables and orders."
                   TextColor="White"/>

            <Entry Placeholder="Email"
                   Keyboard="Email"
                   Text="{Binding Email}" 
                   />

            <Entry Placeholder="Password"
                   IsPassword="True"
                   Text="{Binding Password}" />

            <Button Text="Login"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
